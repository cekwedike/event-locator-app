# Server Configuration
PORT=10000
NODE_ENV=development
APP_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/event_locator

# JWT Configuration
# Generate a strong random secret and NEVER commit the actual secret
JWT_SECRET=<your_generated_jwt_secret>
JWT_EXPIRES_IN=24h

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Supported Languages
SUPPORTED_LANGUAGES=en,es,fr
DEFAULT_LANGUAGE=en

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<your_smtp_username>
SMTP_PASS=<your_smtp_password>
SMTP_FROM=noreply@example.com

# Note: Replace all values in <> with your actual values
# For JWT_SECRET, use a strong random string (min 32 characters)
# Example of generating a secure JWT secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'));" 