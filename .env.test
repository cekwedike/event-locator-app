# Server Configuration
PORT=3001
NODE_ENV=test

# Database Configuration
DATABASE_URL=${DATABASE_URL}
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}

# JWT Configuration
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRES_IN=1h

# Redis Configuration
REDIS_URL=${REDIS_URL}

# Language Configuration
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,it

# Test Configuration
TEST_TIMEOUT=10000
TEST_DATABASE_URL=${DATABASE_URL} 