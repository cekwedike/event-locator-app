# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/event_locator
DB_HOST=localhost
DB_PORT=5432
DB_NAME=event_locator
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Supported Languages
SUPPORTED_LANGUAGES=en,es,fr
DEFAULT_LANGUAGE=en 